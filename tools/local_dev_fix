#!/bin/bash
set -e

clear

SCRIPT_DIR=$(dirname "$0")
REPO_ROOT=$(realpath "$SCRIPT_DIR/..")
cd "$REPO_ROOT"

PYTHON_DIR=src/ani_yt
GO_MODULE_DIR=src/ani_tracker

# --- Python ---
echo "=== Python: ruff format ==="
ruff format $PYTHON_DIR

echo "=== Python: ruff lint & fix ==="
ruff check --fix $PYTHON_DIR

echo "=== Python: pyright type check ==="
pyright $PYTHON_DIR
echo "=== Python done ==="

# --- Go ---
echo "=== Go: auto-fix + lint code ==="

(cd "$GO_MODULE_DIR" && go mod tidy)

(cd "$GO_MODULE_DIR" && gofmt -s -w .)
(cd "$GO_MODULE_DIR" && goimports -w .)
(cd "$GO_MODULE_DIR" && golangci-lint run --fix .)
echo -n "Recheck: "
(cd "$GO_MODULE_DIR" && golangci-lint run .)

cd "$REPO_ROOT"
echo "=== Go done ==="
echo "=== ALL DONE ==="
